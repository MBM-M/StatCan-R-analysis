## 2. Chart 1 — Wages vs. Shelter CPI (indexed to 2014 = 100)

> **The core story:** If shelter costs rise faster than wages, Canadians are falling behind on housing affordability.

```{r chart1-national}
national <- wages_vs_cpi %>% filter(geo == "Canada")

# Reshape to long format — the ggplot2 way
national_long <- national %>%
  select(year, wage_index, shelter_index, cpi_index) %>%
  pivot_longer(
    cols      = c(wage_index, shelter_index, cpi_index),
    names_to  = "series",
    values_to = "index_value"
  ) %>%
  mutate(series = recode(series,
    wage_index    = "Avg Hourly Wage Index",
    shelter_index = "Shelter CPI Index",
    cpi_index     = "All-Items CPI Index"
  ))

ggplot(national_long, aes(x = year, y = index_value, colour = series, linetype = series)) +
  geom_hline(yintercept = 100, colour = "grey60", linewidth = 0.4) +
  geom_line(linewidth = 1.2) +
  geom_point(size = 2) +
  scale_colour_manual(values = c(
    "Avg Hourly Wage Index" = "#2196F3",
    "Shelter CPI Index"    = "#F44336",
    "All-Items CPI Index"  = "#FF9800"
  )) +
  scale_linetype_manual(values = c(
    "Avg Hourly Wage Index" = "solid",
    "Shelter CPI Index"    = "dashed",
    "All-Items CPI Index"  = "dotted"
  )) +
  scale_x_continuous(breaks = seq(2014, 2024, 2)) +
  labs(
    title    = "Wages vs. Housing Costs in Canada (2014 = 100)",
    subtitle = "Shelter CPI rising faster than wages signals declining affordability",
    x        = "Year",
    y        = "Index (2014 = 100)",
    colour   = NULL,
    linetype = NULL
  ) +
  theme_pulse()
```

```{r chart1-gap}
row_2024 <- national %>% filter(year == 2024)
gap      <- row_2024$shelter_index - row_2024$wage_index

cat(sprintf(
  "In 2024 (indexed to 2014 = 100):\n  Wage index:    %.1f\n  Shelter index: %.1f\n  Gap:           +%.1f points\n",
  row_2024$wage_index, row_2024$shelter_index, gap
))
```

