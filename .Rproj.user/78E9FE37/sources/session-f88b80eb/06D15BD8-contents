## 3. Chart 2 — Provincial Comparison: Wage Growth vs. Shelter CPI (2024)

> Which provinces are hit hardest?

```{r chart2-provincial}
PROVINCES <- c(
  "British Columbia", "Alberta", "Saskatchewan", "Manitoba",
  "Ontario", "Quebec", "New Brunswick", "Nova Scotia",
  "Prince Edward Island", "Newfoundland and Labrador"
)

prov_2024 <- wages_vs_cpi %>%
  filter(year == 2024, geo %in% PROVINCES) %>%
  mutate(
    affordability_gap = shelter_index - wage_index,
    geo = fct_reorder(geo, affordability_gap)   # order bars by gap
  )

# Long format for grouped bars
prov_long <- prov_2024 %>%
  select(geo, wage_index, shelter_index) %>%
  pivot_longer(
    cols      = c(wage_index, shelter_index),
    names_to  = "series",
    values_to = "index_value"
  ) %>%
  mutate(series = recode(series,
    wage_index    = "Wage Index (2024)",
    shelter_index = "Shelter CPI Index (2024)"
  ))

ggplot(prov_long, aes(x = index_value, y = geo, fill = series)) +
  geom_col(position = "identity", alpha = 0.75, width = 0.6) +
  scale_fill_manual(values = c(
    "Wage Index (2024)"          = "#2196F3",
    "Shelter CPI Index (2024)"   = "#F44336"
  )) +
  labs(
    title    = "Wage Growth vs. Shelter Cost Growth by Province (2024, indexed to 2014 = 100)",
    subtitle = "Provinces where the red bar exceeds the blue bar have a housing affordability gap",
    x        = "Index (2014 = 100)",
    y        = NULL,
    fill     = NULL
  ) +
  theme_pulse()
```

```{r chart2-table}
prov_2024 %>%
  arrange(desc(affordability_gap)) %>%
  select(Province = geo, `Wage Index` = wage_index,
         `Shelter Index` = shelter_index, `Gap` = affordability_gap) %>%
  mutate(across(where(is.numeric), ~ round(.x, 1)))
```

