## 4. Chart 3 — Employment by Industry Over Time

> Which sectors have grown or shrunk since 2014?

```{r chart3-employment}
# Top 8 industries by 2019 (pre-COVID) employment
top_industries <- emp_annual %>%
  filter(year == 2019) %>%
  slice_max(avg_employed_thousands, n = 8) %>%
  pull(industry)

emp_top <- emp_annual %>%
  filter(industry %in% top_industries) %>%
  mutate(industry = stringr::str_wrap(industry, width = 35))   # wrap long labels

ggplot(emp_top, aes(x = year, y = avg_employed_thousands, colour = industry)) +
  geom_line(linewidth = 1) +
  geom_point(size = 1.5) +
  geom_vline(xintercept = 2020, linetype = "dashed",
             colour = "red", alpha = 0.6) +
  annotate("text", x = 2020.15, y = Inf, label = "COVID-19",
           hjust = 0, vjust = 1.5, colour = "red", size = 3.5) +
  scale_x_continuous(breaks = seq(2014, 2024, 2)) +
  scale_y_continuous(labels = comma) +
  labs(
    title    = "Employment by Industry in Canada (2014–2024)",
    subtitle = "Average employed workers (thousands)",
    x        = "Year",
    y        = "Avg Employed (thousands)",
    colour   = NULL
  ) +
  theme_pulse() +
  theme(legend.text = element_text(size = 9))
```

```{r chart3-recovery}
pre_covid  <- emp_annual %>% filter(year == 2019) %>%
  select(industry, emp_2019 = avg_employed_thousands)

post_covid <- emp_annual %>% filter(year == 2024) %>%
  select(industry, emp_2024 = avg_employed_thousands)

recovery <- pre_covid %>%
  inner_join(post_covid, by = "industry") %>%
  mutate(pct_change = (emp_2024 - emp_2019) / emp_2019 * 100) %>%
  arrange(desc(pct_change))

cat("Employment change 2019 → 2024 (%):\n")
recovery %>%
  mutate(pct_change = round(pct_change, 1)) %>%
  select(Industry = industry, `Change (%)` = pct_change) %>%
  print(n = Inf)
```

