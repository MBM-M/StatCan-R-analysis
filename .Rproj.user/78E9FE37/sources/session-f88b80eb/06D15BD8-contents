## Setup

```{r libraries}
library(dplyr)
library(tidyr)
library(readr)
library(ggplot2)
library(scales)
library(forcats)

PROC <- "processed/"

wages_vs_cpi <- read_csv(paste0(PROC, "wages_vs_cpi.csv"),   show_col_types = FALSE)
